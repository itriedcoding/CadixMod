{
  "name": "cadixmod",
  "version": "1.1.0",
  "description": "A high-performance, cross-platform Discord client mod",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:watch": "node scripts/build.mjs --watch",
    "build:mod": "node scripts/build-mod.mjs",
    "build:desktop": "node -e \"const{execSync}=require('child_process');execSync('npm install',{cwd:'app',stdio:'inherit'});execSync('npm run build',{cwd:'app',stdio:'inherit'})\"",
    "build:all": "node -e \"const{execSync}=require('child_process');execSync('npm run build',{stdio:'inherit'});execSync('npm run build:desktop',{stdio:'inherit'})\"",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "inject": "node scripts/inject.mjs",
    "uninject": "node scripts/uninject.mjs",
    "desktop": "node -e \"const{execSync}=require('child_process');execSync('npm run dev',{cwd:'app',stdio:'inherit'})\"",
    "desktop:build": "node -e \"const{execSync}=require('child_process');execSync('npm run dist',{cwd:'app',stdio:'inherit'})\"",
    "desktop:build:win": "node -e \"const{execSync}=require('child_process');execSync('npm run dist:win',{cwd:'app',stdio:'inherit'})\"",
    "desktop:build:linux": "node -e \"const{execSync}=require('child_process');execSync('npm run dist:linux',{cwd:'app',stdio:'inherit'})\"",
    "desktop:build:mac": "node -e \"const{execSync}=require('child_process');execSync('npm run dist:mac',{cwd:'app',stdio:'inherit'})\"",
    "dist": "node -e \"const{execSync}=require('child_process');execSync('npm run build',{stdio:'inherit'});execSync('node scripts/package.mjs',{stdio:'inherit'})\"",
    "clean": "node -e \"const fs=require('fs');['dist','app/dist','app/release','build'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch{}})\"",
    "setup": "node -e \"const{execSync}=require('child_process');execSync('npm install',{stdio:'inherit'});execSync('npm install',{cwd:'app',stdio:'inherit'});console.log('Setup complete!')\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/itriedcoding/CadixMod.git"
  },
  "author": "itriedcoding",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}
